{
	"name": "Transformation_Dataflow",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "AdlsSourceBronzeDSDF",
						"type": "DatasetReference"
					},
					"name": "Sales"
				},
				{
					"dataset": {
						"referenceName": "AdlsSourceBronzeDSDF",
						"type": "DatasetReference"
					},
					"name": "Product"
				},
				{
					"dataset": {
						"referenceName": "AdlsSourceBronzeDSDF",
						"type": "DatasetReference"
					},
					"name": "Category"
				},
				{
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "AdlsSinkSilverDSDF",
						"type": "DatasetReference"
					},
					"name": "SilverSink"
				}
			],
			"transformations": [
				{
					"name": "JoinT"
				}
			],
			"scriptLines": [
				"source(output(",
				"          SaleID as integer,",
				"          Date as date,",
				"          ProductID as integer,",
				"          CategoryID as integer,",
				"          SubCategoryID as integer,",
				"          SalesRepID as integer,",
				"          GeographyID as integer,",
				"          Amount as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     partitionBy('hash', 1)) ~> Sales",
				"source(output(",
				"          ProductID as integer,",
				"          ProductName as string,",
				"          CategoryID as integer,",
				"          SubCategoryID as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     partitionBy('hash', 1)) ~> Product",
				"source(output(",
				"          CategoryID as integer,",
				"          CategoryName as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     partitionBy('hash', 1)) ~> Category",
				"source(allowSchemaDrift: true,",
				"     validateSchema: false) ~> source1",
				"Sales, Product join(Sales@ProductID == Product@ProductID,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     partitionBy('hash', 1),",
				"     broadcast: 'auto')~> JoinT",
				"JoinT sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['FinalTransformedFile.csv'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> SilverSink"
			]
		}
	}
}