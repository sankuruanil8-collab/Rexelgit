{
	"name": "Transformation_Dataflow",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "AdlsSourceCsvDS",
						"type": "DatasetReference"
					},
					"name": "GetFileCSV1"
				},
				{
					"dataset": {
						"referenceName": "AdlsSourceCsvDS",
						"type": "DatasetReference"
					},
					"name": "GetFileCSV2"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "AdlsSinkCsvDS",
						"type": "DatasetReference"
					},
					"name": "SilverSink"
				},
				{
					"dataset": {
						"referenceName": "AdlsSinkCsvDS",
						"type": "DatasetReference"
					},
					"name": "SilverSink2"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     partitionBy('hash', 1)) ~> GetFileCSV1",
				"source(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     partitionBy('hash', 1)) ~> GetFileCSV2",
				"GetFileCSV1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['Products.csv'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> SilverSink",
				"GetFileCSV2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['Sales_2023.csv'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> SilverSink2"
			]
		}
	}
}