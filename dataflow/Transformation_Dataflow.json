{
	"name": "Transformation_Dataflow",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "AdlsSourceCsvDS",
						"type": "DatasetReference"
					},
					"name": "GetCSVFiles"
				},
				{
					"dataset": {
						"referenceName": "AdlsSourceExcelDS",
						"type": "DatasetReference"
					},
					"name": "GetExcelFiles"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "AdlsSinkCsvDS",
						"type": "DatasetReference"
					},
					"name": "SilverSink"
				}
			],
			"transformations": [
				{
					"name": "JoinT"
				}
			],
			"scriptLines": [
				"source(output(",
				"          SaleID as integer,",
				"          Date as date,",
				"          ProductID as integer,",
				"          CategoryID as integer,",
				"          SubCategoryID as integer,",
				"          SalesRepID as integer,",
				"          GeographyID as integer,",
				"          Amount as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     inferDriftedColumnTypes: true,",
				"     ignoreNoFilesFound: false,",
				"     wildcardPaths:['*.csv'],",
				"     partitionBy('hash', 1)) ~> GetCSVFiles",
				"source(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     inferDriftedColumnTypes: true,",
				"     ignoreNoFilesFound: false,",
				"     wildcardPaths:['*.xlsx'],",
				"     partitionBy('hash', 1)) ~> GetExcelFiles",
				"GetCSVFiles, GetExcelFiles join(ProductID == ERROR_FUNCTION(''),",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> JoinT",
				"JoinT sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['FinalTransformedFile.csv'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> SilverSink"
			]
		}
	}
}