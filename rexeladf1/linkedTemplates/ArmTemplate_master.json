					"trigger1_properties_ETL-Pipeline_parameters_FileName6": {
						"value": "[parameters('trigger1_properties_ETL-Pipeline_parameters_FileName6')]"
					},
					"trigger1_properties_ETL-Pipeline_parameters_GoldContainer": {
						"value": "[parameters('trigger1_properties_ETL-Pipeline_parameters_GoldContainer')]"
					},
					"trigger1_properties_ETL-Pipeline_parameters_SinkTableName": {
						"value": "[parameters('trigger1_properties_ETL-Pipeline_parameters_SinkTableName')]"
