										"value": "@pipeline().parameters.SinkTableName",
										"type": "Expression"
									}
								}
							}
						]
					}
				],
				"parameters": {
					"SourceContainer": {
						"type": "string",
						"defaultValue": "bronze"
					},
					"SinkContainer": {
						"type": "string",
						"defaultValue": "silver"
					},
					"FileName1": {
						"type": "string",
						"defaultValue": "Sales_2023.csv"
					},
					"FileName2": {
						"type": "String",
						"defaultValue": "Products.csv"
					},
					"FileName3": {
						"type": "string",
						"defaultValue": "data_135ac180-99cc-4000-ba39-49d0ad52ff0f_4de9dcb7-997e-4e95-8a87-a2a2835b91f9.csv"
					},
					"FileName4": {
						"type": "string",
						"defaultValue": "data_135ac180-99cc-4000-ba39-49d0ad52ff0f_09099f2f-12ce-47d6-9f9e-b299d119cb4e.csv"
					},
					"FileName5": {
						"type": "string",
						"defaultValue": "data_135ac180-99cc-4000-ba39-49d0ad52ff0f_8dfff9dc-8ba0-47a3-8628-e9c36fb1ff51.csv"
					},
					"FileName6": {
						"type": "string",
						"defaultValue": "data_135ac180-99cc-4000-ba39-49d0ad52ff0f_cc464ea8-fbd6-4563-8a03-ceb5009c926c.csv"
					},
					"SilverContainer": {
						"type": "string",
						"defaultValue": "silver"
					},
					"GoldContainer": {
						"type": "string",
						"defaultValue": "gold"
					},
					"SinkTableName": {
						"type": "string",
						"defaultValue": "Final_Sales_Data"
					}
				},
				"annotations": []
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/dataflows/Transformation_Dataflow')]",
				"[concat(variables('factoryId'), '/datasets/SourcenSinkADLS_CSV_DS')]",
				"[concat(variables('factoryId'), '/datasets/AzureSqlSinkDS')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/Transformation_Dataflow')]",
			"type": "Microsoft.DataFactory/factories/dataflows",
			"apiVersion": "2018-06-01",
			"properties": {
				"type": "MappingDataFlow",
				"typeProperties": {
					"sources": [
						{
							"dataset": {
								"referenceName": "AdlsSourceBronzeDSDF",
								"type": "DatasetReference"
							},
							"name": "Sales"
						},
						{
							"dataset": {
								"referenceName": "AdlsSourceBronzeDSDF",
								"type": "DatasetReference"
							},
							"name": "Product"
						},
						{
							"dataset": {
								"referenceName": "AdlsSourceBronzeDSDF",
								"type": "DatasetReference"
							},
							"name": "Category"
						},
						{
							"dataset": {
								"referenceName": "AdlsSourceBronzeDSDF",
								"type": "DatasetReference"
							},
							"name": "Geography"
						},
						{
							"dataset": {
								"referenceName": "AdlsSourceBronzeDSDF",
								"type": "DatasetReference"
							},
							"name": "SalesRep"
						},
						{
							"dataset": {
								"referenceName": "AdlsSourceBronzeDSDF",
								"type": "DatasetReference"
							},
							"name": "SubCategory"
						}
					],
					"sinks": [
						{
							"dataset": {
								"referenceName": "AdlsSinkSilverDSDF",
								"type": "DatasetReference"
							},
							"name": "SilverSink"
						}
					],
					"transformations": [
						{
							"name": "Join1"
						},
						{
							"name": "join2"
						},
						{
							"name": "join3"
						},
						{
							"name": "join4"
						},
						{
							"name": "join5"
						},
						{
							"name": "SelectColumns"
						},
						{
							"name": "FilterSaleID"
						},
						{
							"name": "PartitionByWindow"
						}
					],
					"scriptLines": [
						"source(output(",
						"          SaleID as integer,",
						"          Date as date,",
						"          ProductID as integer,",
						"          CategoryID as integer,",
						"          SubCategoryID as integer,",
						"          SalesRepID as integer,",
						"          GeographyID as integer,",
						"          Amount as integer",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false,",
						"     partitionBy('hash', 1)) ~> Sales",
						"source(output(",
						"          ProductID as integer,",
						"          ProductName as string,",
						"          CategoryID as integer,",
						"          SubCategoryID as integer",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false,",
						"     partitionBy('hash', 1)) ~> Product",
						"source(output(",
						"          CategoryID as integer,",
						"          CategoryName as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false,",
						"     partitionBy('hash', 1)) ~> Category",
						"source(output(",
						"          GeographyID as integer,",
						"          Country as string,",
						"          Region as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false,",
						"     partitionBy('hash', 1)) ~> Geography",
						"source(output(",
						"          SalesRepID as integer,",
						"          SalesRepName as string,",
						"          Region as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false,",
						"     partitionBy('hash', 1)) ~> SalesRep",
						"source(output(",
						"          SubCategoryID as integer,",
						"          SubCategoryName as string,",
						"          CategoryID as integer",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false,",
						"     partitionBy('hash', 1)) ~> SubCategory",
						"Sales, Product join(Sales@ProductID == Product@ProductID,",
						"     joinType:'left',",
						"     matchType:'exact',",
						"     ignoreSpaces: false,",
						"     partitionBy('hash', 1),",
						"     broadcast: 'auto')~> Join1",
						"Join1, Category join(Sales@CategoryID == Category@CategoryID,",
						"     joinType:'left',",
						"     matchType:'exact',",
						"     ignoreSpaces: false,",
						"     partitionBy('hash', 1),",
						"     broadcast: 'auto')~> join2",
						"join2, Geography join(Sales@GeographyID == Geography@GeographyID,",
						"     joinType:'left',",
						"     matchType:'exact',",
						"     ignoreSpaces: false,",
						"     partitionBy('hash', 1),",
						"     broadcast: 'auto')~> join3",
						"join3, SalesRep join(Sales@SalesRepID == SalesRep@SalesRepID,",
						"     joinType:'left',",
						"     matchType:'exact',",
						"     ignoreSpaces: false,",
						"     partitionBy('hash', 1),",
						"     broadcast: 'auto')~> join4",
						"join4, SubCategory join(Sales@SubCategoryID == SubCategory@SubCategoryID,",
						"     joinType:'left',",
						"     matchType:'exact',",
						"     ignoreSpaces: false,",
						"     partitionBy('hash', 1),",
						"     broadcast: 'auto')~> join5",
						"join5 select(mapColumn(",
						"          SaleID,",
						"          ProductID = Sales@ProductID,",
						"          ProductName,",
						"          CategoryID = Sales@CategoryID,",
						"          CategoryName,",
						"          SubCategoryID = Sales@SubCategoryID,",
						"          SubCategoryName,",
						"          GeographyID = Sales@GeographyID,",
						"          Region = Geography@Region,",
						"          Country,",
						"          SalesRepID = Sales@SalesRepID,",
						"          SalesRepName,",
						"          Amount,",
						"          Date",
						"     ),",
						"     partitionBy('hash', 1),",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> SelectColumns",
						"PartitionByWindow filter(!isNull(SaleID) && rn == 1,",
						"     partitionBy('hash', 1)) ~> FilterSaleID",
						"SelectColumns window(over(SaleID),",
						"     asc(Date, true),",
						"     rn = rowNumber()) ~> PartitionByWindow",
						"FilterSaleID sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     partitionFileNames:['FinalTransformedFile.csv'],",
						"     umask: 0022,",
						"     preCommands: [],",
						"     postCommands: [],",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true,",
						"     partitionBy('hash', 1)) ~> SilverSink"
					]
				}
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/datasets/AdlsSourceBronzeDSDF')]",
				"[concat(variables('factoryId'), '/datasets/AdlsSinkSilverDSDF')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/SourcenSinkADLS_CSV_DS')]",
			"type": "Microsoft.DataFactory/factories/datasets",
			"apiVersion": "2018-06-01",
			"properties": {
