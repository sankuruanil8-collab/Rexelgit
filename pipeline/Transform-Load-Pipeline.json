{
	"name": "Transform-Load-Pipeline",
	"properties": {
		"activities": [
			{
				"name": "BronzeToSilverDataFlow",
				"type": "ExecuteDataFlow",
				"dependsOn": [],
				"policy": {
					"timeout": "0.00:15:00",
					"retry": 1,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"dataflow": {
						"referenceName": "Transformation_Dataflow",
						"type": "DataFlowReference",
						"datasetParameters": {
							"Sales": {
								"Container": {
									"value": "@pipeline().parameters.SourceContainer",
									"type": "Expression"
								},
								"FileName": {
									"value": "@pipeline().parameters.FileName1",
									"type": "Expression"
								}
							},
							"Product": {
								"Container": {
									"value": "@pipeline().parameters.SourceContainer",
									"type": "Expression"
								},
								"FileName": {
									"value": "@pipeline().parameters.FileName2",
									"type": "Expression"
								}
							},
							"Category": {
								"Container": {
									"value": "@pipeline().parameters.SourceContainer",
									"type": "Expression"
								},
								"FileName": {
									"value": "@pipeline().parameters.FileName3",
									"type": "Expression"
								}
							},
							"Geography": {
								"Container": {
									"value": "@pipeline().parameters.SourceContainer",
									"type": "Expression"
								},
								"FileName": {
									"value": "@pipeline().parameters.FileName4",
									"type": "Expression"
								}
							},
							"SalesRep": {
								"Container": {
									"value": "@pipeline().parameters.SourceContainer",
									"type": "Expression"
								},
								"FileName": {
									"value": "@pipeline().parameters.FileName5",
									"type": "Expression"
								}
							},
							"SubCategory": {
								"Container": {
									"value": "@pipeline().parameters.SourceContainer",
									"type": "Expression"
								},
								"FileName": {
									"value": "@pipeline().parameters.FileName6",
									"type": "Expression"
								}
							},
							"SilverSink": {
								"Container": {
									"value": "@pipeline().parameters.SinkContainer",
									"type": "Expression"
								}
							}
						}
					},
					"compute": {
						"coreCount": 8,
						"computeType": "General"
					},
					"traceLevel": "Fine"
				}
			},
			{
				"name": "CopySilverToGold",
				"type": "Copy",
				"dependsOn": [
					{
						"activity": "BronzeToSilverDataFlow",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.00:15:00",
					"retry": 1,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "DelimitedTextSource",
						"storeSettings": {
							"type": "AzureBlobFSReadSettings",
							"recursive": true,
							"wildcardFileName": "FinalTransformedFile.csv",
							"enablePartitionDiscovery": false
						},
						"formatSettings": {
							"type": "DelimitedTextReadSettings"
						}
					},
					"sink": {
						"type": "DelimitedTextSink",
						"storeSettings": {
							"type": "AzureBlobFSWriteSettings"
						},
						"formatSettings": {
							"type": "DelimitedTextWriteSettings",
							"quoteAllText": true,
							"fileExtension": ".csv"
						}
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"mappings": [
							{
								"source": {
									"name": "SaleID",
									"type": "Int32",
									"physicalType": "String"
								},
								"sink": {
									"name": "SaleID",
									"type": "String",
									"physicalType": "String"
								}
							},
							{
								"source": {
									"name": "ProductID",
									"type": "Int32",
									"physicalType": "String"
								},
								"sink": {
									"name": "ProductID",
									"type": "String",
									"physicalType": "String"
								}
							},
							{
								"source": {
									"name": "ProductName",
									"type": "String",
									"physicalType": "String"
								},
								"sink": {
									"name": "ProductName",
									"type": "String",
									"physicalType": "String"
								}
							},
							{
								"source": {
									"name": "CategoryID",
									"type": "Int32",
									"physicalType": "String"
								},
								"sink": {
									"name": "CategoryID",
									"type": "String",
									"physicalType": "String"
								}
							},
							{
								"source": {
									"name": "CategoryName",
									"type": "String",
									"physicalType": "String"
								},
								"sink": {
									"name": "CategoryName",
									"type": "String",
									"physicalType": "String"
								}
							},
							{
								"source": {
									"name": "SubCategoryID",
									"type": "Int32",
									"physicalType": "String"
								},
								"sink": {
									"name": "SubCategoryID",
									"type": "String",
									"physicalType": "String"
								}
							},
							{
								"source": {
									"name": "SubCategoryName",
									"type": "String",
									"physicalType": "String"
								},
								"sink": {
									"name": "SubCategoryName",
									"type": "String",
									"physicalType": "String"
								}
							},
							{
								"source": {
									"name": "GeographyID",
									"type": "Int32",
									"physicalType": "String"
								},
								"sink": {
									"name": "GeographyID",
									"type": "String",
									"physicalType": "String"
								}
							},
							{
								"source": {
									"name": "Region",
									"type": "String",
									"physicalType": "String"
								},
								"sink": {
									"name": "Region",
									"type": "String",
									"physicalType": "String"
								}
							},
							{
								"source": {
									"name": "Country",
									"type": "String",
									"physicalType": "String"
								},
								"sink": {
									"name": "Country",
									"type": "String",
									"physicalType": "String"
								}
							},
							{
								"source": {
									"name": "SalesRepID",
									"type": "Int32",
									"physicalType": "String"
								},
								"sink": {
									"name": "SalesRepID",
									"type": "String",
									"physicalType": "String"
								}
							},
							{
								"source": {
									"name": "SalesRepName",
									"type": "String",
									"physicalType": "String"
								},
								"sink": {
									"name": "SalesRepName",
									"type": "String",
									"physicalType": "String"
								}
							},
							{
								"source": {
									"name": "Amount",
									"type": "Int32",
									"physicalType": "String"
								},
								"sink": {
									"name": "Amount",
									"type": "String",
									"physicalType": "String"
								}
							},
							{
								"source": {
									"name": "Date",
									"type": "String",
									"physicalType": "String"
								},
								"sink": {
									"name": "Date",
									"type": "String",
									"physicalType": "String"
								}
							}
						],
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "SourcenSinkADLS_CSV_DS",
						"type": "DatasetReference",
						"parameters": {
							"Container": {
								"value": "@pipeline().parameters.SilverContainer",
								"type": "Expression"
							}
						}
					}
				],
				"outputs": [
					{
						"referenceName": "SourcenSinkADLS_CSV_DS",
						"type": "DatasetReference",
						"parameters": {
							"Container": {
								"value": "@pipeline().parameters.GoldContainer",
								"type": "Expression"
							}
						}
					}
				]
			},
			{
				"name": "CopyGoldToSQLDB",
				"type": "Copy",
				"dependsOn": [
					{
						"activity": "CopySilverToGold",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.00:15:00",
					"retry": 1,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "DelimitedTextSource",
						"storeSettings": {
							"type": "AzureBlobFSReadSettings",
							"recursive": true,
							"wildcardFileName": "FinalTransformedFile.csv",
							"enablePartitionDiscovery": false
						},
						"formatSettings": {
							"type": "DelimitedTextReadSettings"
						}
					},
					"sink": {
						"type": "AzureSqlSink",
						"preCopyScript": "Truncate Table Final_Sales_Data;",
						"writeBehavior": "insert",
						"sqlWriterUseTableLock": false,
						"disableMetricsCollection": false
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "SourcenSinkADLS_CSV_DS",
						"type": "DatasetReference",
						"parameters": {
							"Container": {
								"value": "@pipeline().parameters.GoldContainer",
								"type": "Expression"
							}
						}
					}
				],
				"outputs": [
					{
						"referenceName": "AzureSqlSinkDS",
						"type": "DatasetReference",
						"parameters": {
							"TableName": {
								"value": "@pipeline().parameters.SinkTableName",
								"type": "Expression"
							}
						}
					}
				]
			}
		],
		"parameters": {
			"SourceContainer": {
				"type": "string",
				"defaultValue": "bronze"
			},
			"SinkContainer": {
				"type": "string",
				"defaultValue": "silver"
			},
			"FileName1": {
				"type": "string",
				"defaultValue": "Sales_2023.csv"
			},
			"FileName2": {
				"type": "String",
				"defaultValue": "Products.csv"
			},
			"FileName3": {
				"type": "string",
				"defaultValue": "data_135ac180-99cc-4000-ba39-49d0ad52ff0f_4de9dcb7-997e-4e95-8a87-a2a2835b91f9.csv"
			},
			"FileName4": {
				"type": "string",
				"defaultValue": "data_135ac180-99cc-4000-ba39-49d0ad52ff0f_09099f2f-12ce-47d6-9f9e-b299d119cb4e.csv"
			},
			"FileName5": {
				"type": "string",
				"defaultValue": "data_135ac180-99cc-4000-ba39-49d0ad52ff0f_8dfff9dc-8ba0-47a3-8628-e9c36fb1ff51.csv"
			},
			"FileName6": {
				"type": "string",
				"defaultValue": "data_135ac180-99cc-4000-ba39-49d0ad52ff0f_cc464ea8-fbd6-4563-8a03-ceb5009c926c.csv"
			},
			"SilverContainer": {
				"type": "string",
				"defaultValue": "silver"
			},
			"GoldContainer": {
				"type": "string",
				"defaultValue": "gold"
			},
			"SinkTableName": {
				"type": "string",
				"defaultValue": "Final_Sales_Data"
			}
		},
		"annotations": []
	}
}