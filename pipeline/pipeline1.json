{
	"name": "pipeline1",
	"properties": {
		"activities": [
			{
				"name": "Data flow1",
				"type": "ExecuteDataFlow",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"dataflow": {
						"referenceName": "Transformation_Dataflow",
						"type": "DataFlowReference",
						"datasetParameters": {
							"GetFileCSV1": {
								"Container": {
									"value": "@pipeline().parameters.SourceContainer",
									"type": "Expression"
								},
								"FileName": {
									"value": "@pipeline().parameters.FileName1",
									"type": "Expression"
								}
							},
							"GetFileCSV2": {
								"Container": {
									"value": "@pipeline().parameters.SourceContainer",
									"type": "Expression"
								},
								"FileName": {
									"value": "@pipeline().parameters.FileName2",
									"type": "Expression"
								}
							},
							"SilverSink2": {
								"Container": {
									"value": "@pipeline().parameters.SinkContainer",
									"type": "Expression"
								}
							}
						}
					},
					"compute": {
						"coreCount": 8,
						"computeType": "General"
					},
					"traceLevel": "Fine"
				}
			}
		],
		"parameters": {
			"SourceContainer": {
				"type": "string",
				"defaultValue": "bronze"
			},
			"SinkContainer": {
				"type": "string",
				"defaultValue": "silver"
			},
			"FileName1": {
				"type": "string",
				"defaultValue": "Products.csv"
			},
			"FileName2": {
				"type": "String",
				"defaultValue": "Sales_2023.csv"
			}
		},
		"annotations": []
	}
}